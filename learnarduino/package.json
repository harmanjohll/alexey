{
  "name": "arduinolab",
  "version": "1.0.0",
  "private": true,
  "description": "Arduino learning platform for Alexey",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
